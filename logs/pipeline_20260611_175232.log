            << "Symbol : " << SymbolChar[uniqueSymbols[s]]
            << " | Count : " << left2right
            << " | Ways : " << ways
            << " | Pay : " << PayTable_1[uniqueSymbols[s]][left2right]
            << " | Total Win : " << symbol_win
            << endl;
        win += symbol_win;
    }
    return win;

}


