   222	inline void validateWindow(const PayWindow& pay_window) {
   223	    if (pay_window.size() != NO_OF_ROWS) throw std::runtime_error("pay_window row count is not 4");
   224	    for (const auto& row : pay_window) {
   225	        if (row.size() != NO_OF_REELS) throw std::runtime_error("pay_window reel count is not 6");
   226	    }
   227	}
   228	
   229	inline int sampleWeighted(const std::vector<int>& weights, std::mt19937& rng) {
   230	    if (!g_forcedWeightedIndexes.empty()) {
   231	        int idx = g_forcedWeightedIndexes.front();
   232	        g_forcedWeightedIndexes.erase(g_forcedWeightedIndexes.begin());
   233	        if (idx < 0 || idx >= static_cast<int>(weights.size())) throw std::runtime_error("forced weighted index out of range");
   234	        return idx;
   235	    }
   236	    std::discrete_distribution<int> dist(weights.begin(), weights.end());
   237	    return dist(rng);
   238	}
   239	
   240	inline PayWindow generatePayWindow(const ReelSet& ReelSetArg, const std::vector<int>& ReelSize, std::mt19937& rng) {
   241	    Trace trace(__func__);
   242	    trace.input("ReelSet", ReelSetArg);
   243	    trace.input("ReelSize", ReelSize);
   244	    trace.GlobalandStruct("NO_OF_ROWS", NO_OF_ROWS);
   245	    trace.GlobalandStruct("NO_OF_REELS", NO_OF_REELS);
   246	
   247	    if (ReelSetArg.size() != NO_OF_REELS || ReelSize.size() != NO_OF_REELS) {
   248	        throw std::runtime_error("ReelSet/ReelSize shape mismatch");
   249	    }
   250	    PayWindow pay_window(NO_OF_ROWS, std::vector<Symbol>(NO_OF_REELS));
   251	    for (int reel = 0; reel < NO_OF_REELS; ++reel) {
   252	        if (static_cast<int>(ReelSetArg[reel].size()) != ReelSize[reel]) {
   253	            throw std::runtime_error("ReelSize does not match reel strip length");
   254	        }
   255	        int stop = 0;
   256	        if (!g_forcedStops.empty()) {
   257	            stop = g_forcedStops.front();
   258	            g_forcedStops.erase(g_forcedStops.begin());
   259	            stop %= ReelSize[reel];
   260	            if (stop < 0) stop += ReelSize[reel];
   261	        } else {
   262	            std::uniform_int_distribution<int> dist(0, ReelSize[reel] - 1);
   263	            stop = dist(rng);
   264	        }
   265	        for (int row = 0; row < NO_OF_ROWS; ++row) {
   266	            pay_window[row][reel] = ReelSetArg[reel][(stop + row) % ReelSize[reel]];
   267	        }
   268	    }
   269	    trace.output("pay_window", pay_window);
   270	    return pay_window;
   271	}
   272	
   273	inline PayWindow additionalCOR(PayWindow pay_window, std::mt19937& rng) {
   274	    Trace trace(__func__);
   275	    trace.input("pay_window", pay_window);
   276	    trace.GlobalandStruct("probTable.corTrigger", probTable.corTrigger);
   277	    trace.GlobalandStruct("probTable.numCorWeight", probTable.numCorWeight);
   278	    trace.GlobalandStruct("probTable.baseCORValueWeights.values", probTable.baseCORValueWeights.values);
   279	    trace.GlobalandStruct("probTable.baseCORValueWeights.weights", probTable.baseCORValueWeights.weights);
   280	    validateWindow(pay_window);
   281	
   282	    int trigger = sampleWeighted(probTable.corTrigger, rng);
   283	    if (trigger == 0) {
   284	        int count = sampleWeighted(probTable.numCorWeight, rng) + 1;
   285	        std::vector<Cell> eligible;
   286	        for (int row = 0; row < NO_OF_ROWS; ++row) {
   287	            for (int reel = 0; reel < NO_OF_REELS; ++reel) {
   288	                Symbol s = pay_window[row][reel];
   289	                if (s != COLLECT && s != WILD && s != SCAT) eligible.push_back({row, reel});
   290	            }
   291	        }
   292	        std::shuffle(eligible.begin(), eligible.end(), rng);
   293	        int placements = std::min(count, static_cast<int>(eligible.size()));
   294	        for (int i = 0; i < placements; ++i) {
   295	            Cell cell = eligible[i];
   296	            pay_window[cell.first][cell.second] = COR;
   297	            int value_index = sampleWeighted(probTable.baseCORValueWeights.weights, rng);
   298	            g_corValues[cell] = probTable.baseCORValueWeights.values[value_index];
   299	        }
   300	    }
   301	
   302	    trace.output("pay_window", pay_window);
   303	    return pay_window;
   304	}
   305	
   306	inline int countScatterAnywhere(const PayWindow& pay_window) {
   307	    int count = 0;
   308	    for (const auto& row : pay_window) for (Symbol s : row) if (s == SCAT) ++count;
   309	    return count;
   310	}
   311	
   312	inline int countScatterLeftToRight(const PayWindow& pay_window) {
   313	    int count = 0;
   314	    for (int reel = 0; reel < NO_OF_REELS; ++reel) {
   315	        int reel_count = 0;
   316	        for (int row = 0; row < NO_OF_ROWS; ++row) if (pay_window[row][reel] == SCAT) ++reel_count;
   317	        if (reel_count == 0) break;
   318	        count += reel_count;
   319	    }
   320	    return std::min(count, NO_OF_REELS);
   321	}
   322	
   323	inline WinBreakdown calculateWaysNoTrace(const PayWindow& pay_window) {
   324	    WinBreakdown result;
   325	    for (Symbol sym : StandardSymbols) {
   326	        int symbol_count = 0;
   327	        int ways = 1;
   328	        for (int reel = 0; reel < NO_OF_REELS; ++reel) {
   329	            int matches = 0;
   330	            for (int row = 0; row < NO_OF_ROWS; ++row) {
   331	                Symbol cell = pay_window[row][reel];
   332	                if (cell == sym || cell == WILD) ++matches;
   333	            }
   334	            if (matches == 0) break;
   335	            ways *= matches;
   336	            ++symbol_count;
   337	        }
   338	        result.symbol_hits[sym] = symbol_count;
   339	        int pay = PayTable[paytableRow(sym)][symbol_count];
   340	        if (pay > 0) result.ways_win += pay * ways;
   341	    }
   342	    result.scatter_count = countScatterAnywhere(pay_window);
   343	    int capped_scatter = std::min(result.scatter_count, NO_OF_REELS);
   344	    result.scatter_win = PayTable[paytableRow(SCAT)][capped_scatter];
   345	    return result;
   346	}
   347	
   348	inline WinBreakdown waysWinCalculation(const PayWindow& pay_window) {
   349	    Trace trace(__func__);
   350	    trace.input("pay_window", pay_window);
   351	    trace.GlobalandStruct("PayTable", PayTable);
   352	    trace.GlobalandStruct("STANDARD_SYMBOL_COUNT", STANDARD_SYMBOL_COUNT);
   353	    validateWindow(pay_window);
   354	
   355	    WinBreakdown result = calculateWaysNoTrace(pay_window);
   356	    int win = result.ways_win + result.scatter_win;
   357	    trace.output("win", win);
   358	    return result;
   359	}
   360	
   361	inline WinBreakdown waysWinCalculationWithMultiplier(const PayWindow& pay_window, const std::map<Cell, int>& wild_multipliers = {}) {
   362	    Trace trace(__func__);
   363	    trace.input("pay_window", pay_window);
   364	    trace.GlobalandStruct("probTable.wildMult", probTable.wildMult);
   365	    trace.GlobalandStruct("PayTable", PayTable);
   366	    validateWindow(pay_window);
   367	
   368	    std::map<Cell, int> active_multipliers = wild_multipliers.empty() ? g_wildMultipliers : wild_multipliers;
   369	    static std::mt19937 multiplier_rng(5489u);
   370	    for (int row = 0; row < NO_OF_ROWS; ++row) {
   371	        for (int reel = 0; reel < NO_OF_REELS; ++reel) {
   372	            if (pay_window[row][reel] == WILD && !active_multipliers.count({row, reel})) {
   373	                int idx = sampleWeighted(probTable.wildMult, multiplier_rng);
   374	                active_multipliers[{row, reel}] = idx == 0 ? 2 : idx == 1 ? 3 : 5;
   375	            }
   376	        }
   377	    }
   378	
   379	    WinBreakdown result = calculateWaysNoTrace(pay_window);
   380	    int product = 1;
   381	    for (const auto& kv : active_multipliers) {
   382	        int row = kv.first.first;
   383	        int reel = kv.first.second;
   384	        if (row >= 0 && row < NO_OF_ROWS && reel >= 0 && reel < NO_OF_REELS && pay_window[row][reel] == WILD) {
   385	            product *= kv.second;
   386	        }
   387	    }
   388	    result.ways_win *= product;
   389	    if (freeSpinsScatterEvaluationRule == ScatterEvaluationRule::LEFT_TO_RIGHT) {
   390	        result.scatter_count = countScatterLeftToRight(pay_window);
   391	        result.scatter_win = PayTable[paytableRow(SCAT)][std::min(result.scatter_count, NO_OF_REELS)];
   392	    }
   393	    int session_win = result.ways_win + result.scatter_win;
   394	    trace.output("session_win", session_win);
   395	    return result;
   396	}
   397	
   398	inline CollectResult resolveCollect(const PayWindow& pay_window, int bet_fixed_coins) {
   399	    Trace trace(__func__);
   400	    trace.input("pay_window", pay_window);
   401	    trace.input("bet_fixed_coins", bet_fixed_coins);
   402	    trace.GlobalandStruct("probTable.CORValues", probTable.CORValues);
   403	    validateWindow(pay_window);
   404	
   405	    CollectResult result;
   406	    for (int row = 0; row < NO_OF_ROWS; ++row) {
   407	        if (pay_window[row][0] == COLLECT) ++result.collect_count;
   408	        if (pay_window[row][NO_OF_REELS - 1] == COLLECT) ++result.collect_count;
   409	    }
   410	    for (int row = 0; row < NO_OF_ROWS; ++row) {
   411	        for (int reel = 0; reel < NO_OF_REELS; ++reel) {
   412	            if (pay_window[row][reel] == COR) {
   413	                auto it = g_corValues.find({row, reel});
   414	                if (it != g_corValues.end()) result.cor_value_x_bet_sum += it->second;
   415	            }
   416	        }
   417	    }
   418	    result.collect_win = static_cast<int>(result.collect_count * result.cor_value_x_bet_sum * bet_fixed_coins + 0.00001);
   419	    trace.output("CollectResult", result);
   420	    return result;

