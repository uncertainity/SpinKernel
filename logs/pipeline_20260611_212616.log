    71	                  << " shape:" << shape_of(value) << "\n";
    72	    }
    73	
    74	    template<typename T>
    75	    void GlobalandStruct(const std::string& name, const T& value) {
    76	        std::cout << std::string(depth * 2, ' ')
    77	                  << "Global/Struct " << name << ": " << type_name<T>()
    78	                  << " shape:" << shape_of(value) << "\n";
    79	    }
    80	
    81	    ~Trace() {
    82	        depth--;
    83	        std::cout << std::string(depth * 2, ' ') << "<- " << fn << "\n";
    84	    }
