std::string type_name() {
    int status = 0;

    std::unique_ptr<char, void(*)(void*)> res{
        abi::__cxa_demangle(typeid(T).name(), nullptr, nullptr, &status),
        std::free
    };

    return status == 0 ? res.get() : typeid(T).name();
}

