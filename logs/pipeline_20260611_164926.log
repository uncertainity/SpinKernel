reelsets = {
    'BG1_Reels': {'planner_key':'reel_strips.base_B1','strips': planner['reel_strips']['base_B1'], 'sizes': reel_sizes(planner['reel_strips']['base_B1'])},
    'BG2_Reels': {'planner_key':'reel_strips.base_B2','strips': planner['reel_strips']['base_B2'], 'sizes': reel_sizes(planner['reel_strips']['base_B2'])},
    'FG1_Reels': {'planner_key':'reel_strips.free_F1','strips': planner['reel_strips']['free_F1'], 'sizes': reel_sizes(planner['reel_strips']['free_F1'])},
