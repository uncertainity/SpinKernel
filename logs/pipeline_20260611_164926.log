    {'name':'waysWinCalculation','purpose':'Evaluate left-to-right 4096 ways wins for standard symbols and calculate SCAT win separately according to the selected SCAT evaluation rule.','inputs':[{'name':'pay_window','type':'PayWindow','shape':'[4x6]'}],'outputs':[{'name':'WinBreakdown','type':'struct','shape':'[1]','fields':['ways_win','scatter_win','scatter_count','symbol_hits']}],'global_dependencies':['PayTable','STANDARD_SYMBOL_COUNT','standard_symbols','WILD substitution rules','SCAT evaluation rule'],'pseudocode':['Identify unique standard symbols present on reel 1.','For each standard symbol, count matching symbol or WILD occurrences on consecutive reels from reel 1.','Stop at first reel with zero matches.','Multiply occurrence counts to compute ways.','Look up paytable by symbol and consecutive reel count.','Add paytable value times ways to ways_win.','Count SCAT symbols and calculate scatter_win using unresolved configured SCAT mode.','Return WinBreakdown.']},
    {'name':'waysWinCalculationWithMultiplier','purpose':'Evaluate Free Spins ways and SCAT wins, applying the product of all visible WILD multipliers to ways wins only.','inputs':[{'name':'pay_window','type':'PayWindow','shape':'[4x6]'},{'name':'wild_multipliers','type':'map<Cell,int>','shape':'variable'}],'outputs':[{'name':'WinBreakdown','type':'struct','shape':'[1]'}],'global_dependencies':['PayTable','probTable.wildMult','SCAT evaluation rule'],'pseudocode':['Assign each visible WILD a multiplier sampled from wildMult.','Evaluate base ways/scatter breakdown using waysWinCalculation semantics.','Compute product of every visible WILD multiplier; if no WILD is visible, product is 1.','Multiply ways_win by the product.','Do not multiply scatter_win.','Return WinBreakdown.']},
    {'name':'resolveCollect','purpose':'Collect all visible COR and jackpot-valued COR symbols once for each visible COLLECT symbol.','inputs':[{'name':'pay_window','type':'PayWindow','shape':'[4x6]'},{'name':'bet_fixed_coins','type':'int','shape':'[1]'}],'outputs':[{'name':'CollectResult','type':'struct','shape':'[1]','fields':['collect_count','cor_value_x_bet_sum','collect_win']}],'global_dependencies':['COLLECT allowed reels','COR values','jackpot xBet values'],'pseudocode':['Count COLLECT symbols on reels 1 and 6.','Sum visible COR and jackpot-valued COR xBet values.','Set collect_win = collect_count * cor_value_x_bet_sum * bet_fixed_coins.','Return CollectResult.']},
    {'name':'FreeGameFeature_1','canonical_name':'FreeSpinsFeature','purpose':'Run a Free Spins session using FG1 for natural triggers and configured buy-bonus free reelsets for buy-bonus mode.','inputs':[{'name':'num_of_free_spins','type':'int','shape':'[1]'},{'name':'trigger_source','type':'enum TriggerSource','shape':'[1]'}],'outputs':[{'name':'FeatureResult','type':'struct','shape':'[1]'}],'global_dependencies':['FG1_Reels','FG1_ReelSize','probTable.wildMult','free spin retrigger awards'],'pseudocode':['Initialize remaining spins to awarded spins and session_win to zero.','While remaining spins > 0, generate one Free Spins pay window.','Assign WILD multipliers and evaluate with waysWinCalculationWithMultiplier.','Add ways and scatter wins to session_win.','Count SCAT and add retrigger spins for 2/3/4/5/6 SCAT.','Decrement consumed spin and continue until no spins remain.','Return FeatureResult.']},
    {'name':'FreeGameFeature_2','canonical_name':'BlitzSpinsFeature','purpose':'Run Blitz Spins; trace name is retained as an alias but the feature is Blitz, not Free Spins.','inputs':[{'name':'num_of_blitz_spins','type':'int','shape':'[1]'}],'outputs':[{'name':'FeatureResult','type':'struct','shape':'[1]'}],'global_dependencies':['probTable.freeGamenumCollect','probTable.freeGameCOROccur','probTable.goodCORTable','probTable.badCORTable','probTable.CORValues'],'pseudocode':['For each Blitz spin, create an empty 4x6 Blitz window.','Sample one or two COLLECT symbols and place them on reels 1 and/or 6 with at most one COLLECT per reel.','For every non-COLLECT cell, sample COR occurrence.','If no COR appears, force one COR.','Assign exactly one COR value from goodCORTable and all other COR values from badCORTable over CORValues.','Resolve Collect for the Blitz window.','Add spin collect win to session_win.','Return FeatureResult after all Blitz spins.']}
]

