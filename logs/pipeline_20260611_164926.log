corrected_trace = '''// CORRECTED TRACE REFERENCE - Simulator stage
// Source: validation/oracle/trace_ref.txt
// Storage convention: PayWindow is row-major [NO_OF_ROWS x NO_OF_REELS] = [4x6].
// Canonical symbol names use SCAT; SCATTER is accepted only as a trace alias.

GLOBAL CONSTANTS
NO_OF_REELS = 6
