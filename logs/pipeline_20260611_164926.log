    'freeGameCOROccur': {'source':'features.blitz_spins.cor_occurrence_weights','values': planner['features']['blitz_spins']['cor_occurrence_weights'], 'shape':'[2]', 'note':'Trace name retained as alias; table belongs to Blitz Spins.'},
    'goodCORTable': {'source':'mathematical_dependencies.blitz_cor_value_weights.good','values': planner['mathematical_dependencies']['blitz_cor_value_weights']['good'], 'shape':'[22]'},
