from zipfile import ZipFile
from xml.etree import ElementTree as ET
import re

def colnum(ref):
    m=re.match(r'([A-Z]+)', ref)
    if not m: return 0
    n=0
    for ch in m.group(1): n=n*26+ord(ch)-64
    return n

def load_xlsx(path):
    z=ZipFile(path)
    ns={'a':'http://schemas.openxmlformats.org/spreadsheetml/2006/main','r':'http://schemas.openxmlformats.org/officeDocument/2006/relationships','rel':'http://schemas.openxmlformats.org/package/2006/relationships'}
    shared=[]
    if 'xl/sharedStrings.xml' in z.namelist():
        root=ET.fromstring(z.read('xl/sharedStrings.xml'))
        for si in root.findall('.//a:si', ns):
            shared.append(''.join(t.text or '' for t in si.findall('.//a:t', ns)))
    relroot=ET.fromstring(z.read('xl/_rels/workbook.xml.rels'))
    rels={rel.attrib['Id']: rel.attrib['Target'] for rel in relroot.findall('rel:Relationship', ns)}
    wb=ET.fromstring(z.read('xl/workbook.xml'))
    sheets=[]
    for sh in wb.findall('.//a:sheets/a:sheet', ns):
        rid=sh.attrib['{http://schemas.openxmlformats.org/officeDocument/2006/relationships}id']
        target=rels[rid]
        if not target.startswith('xl/'): target='xl/'+target
        sheets.append((sh.attrib['name'], target))
    return z, shared, sheets, ns

def cell_value(c, shared, ns):
    t=c.attrib.get('t')
    v=c.find('a:v', ns)
    if t=='inlineStr':
        return ''.join(x.text or '' for x in c.findall('.//a:t', ns))
    if v is None: return ''
    txt=v.text or ''
    if t=='s':
        return shared[int(txt)] if txt.isdigit() and int(txt)<len(shared) else txt
    if t=='b': return 'TRUE' if txt=='1' else 'FALSE'
    return txt

def dump(path, want=None, max_rows=80, max_cols=30):
    z, shared, sheets, ns=load_xlsx(path)
    print('\\n###', path)
    for name,target in sheets:
        if want and name not in want: continue
        root=ET.fromstring(z.read(target))
        rows=[]
        for row in root.findall('.//a:sheetData/a:row', ns):
            vals=[]
            for c in row.findall('a:c', ns):
                ref=c.attrib.get('r','')
                cn=colnum(ref)
                if cn<=max_cols:
                    val=cell_value(c, shared, ns)
                    if val"'!='"'': vals.append((ref,val))
            if vals: rows.append((int(row.attrib.get('r','0')),vals))
        print('\\nSHEET', name, 'nonempty_rows', len(rows))
        for r, vals in rows[:max_rows]:
            print(f'R{r}: ' + ' | '.join(f'{ref}={val}' for ref,val in vals))
        if len(rows)>max_rows: print('...')

dump('./input/gameRule/VegasBlitz_GameRule.xlsx', max_rows=120, max_cols=20)
dump('./input/mathModel/Parsheet_Vegas_Blitz.xlsx', want={'Game Rules','Implementation'}, max_rows=140, max_cols=24)
dump('./validation/testCases/Vegas_Blitz_Test_Cases.xlsx', want={'Payouts Verification','Test Scenarios','Math and GDD','RA','Server force','Sheet1'}, max_rows=120, max_cols=20)
