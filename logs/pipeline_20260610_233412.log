from zipfile import ZipFile
from xml.etree import ElementTree as ET
import re, os, json
NS={'main':'http://schemas.openxmlformats.org/spreadsheetml/2006/main','rel':'http://schemas.openxmlformats.org/officeDocument/2006/relationships','pkgrel':'http://schemas.openxmlformats.org/package/2006/relationships'}

def colnum(ref):
    m=re.match(r'([A-Z]+)',ref)
    n=0
    for ch in m.group(1): n=n*26+ord(ch)-64
    return n

def load(path):
    z=ZipFile(path)
    shared=[]
    if 'xl/sharedStrings.xml' in z.namelist():
        root=ET.fromstring(z.read('xl/sharedStrings.xml'))
        for si in root.findall('main:si',NS):
            parts=[]
            for t in si.findall('.//main:t',NS): parts.append(t.text or '')
            shared.append(''.join(parts))
    wb=ET.fromstring(z.read('xl/workbook.xml'))
    rels=ET.fromstring(z.read('xl/_rels/workbook.xml.rels'))
    relmap={r.attrib['Id']:r.attrib['Target'] for r in rels}
    sheets=[]
    for s in wb.findall('.//main:sheet',NS):
        name=s.attrib['name']; rid=s.attrib['{http://schemas.openxmlformats.org/officeDocument/2006/relationships}id']
        target=relmap[rid]
        if not target.startswith('xl/'): target='xl/'+target
        sheets.append((name,target))
    print('\\n###',path)
    for name,target in sheets:
        root=ET.fromstring(z.read(target))
        rows=[]
        for row in root.findall('.//main:sheetData/main:row',NS):
            vals=[]
            maxc=0
            for c in row.findall('main:c',NS):
                r=c.attrib.get('r','A1'); idx=colnum(r); maxc=max(maxc,idx)
                while len(vals)<idx-1: vals.append('')
                typ=c.attrib.get('t')
                v=c.find('main:v',NS)
                val=''
                if typ=='inlineStr':
                    val=''.join(t.text or '' for t in c.findall('.//main:t',NS))
                elif v is not None:
                    val=v.text or ''
                    if typ=='s':
                        val=shared[int(val)] if val.isdigit() and int(val)<len(shared) else val
                    elif typ=='b':
                        val='TRUE' if val=='1' else 'FALSE'
                vals.append(val)
            # trim trailing blanks
            while vals and vals[-1]=='': vals.pop()
            if any(str(x).strip() for x in vals):
                rows.append(vals)
        print(f'-- SHEET {name} rows={len(rows)}')
        for i,row in enumerate(rows[:80],1):
            print(f'{i}: ' + ' | '.join(str(x) for x in row))
        if len(rows)>80: print(f'... {len(rows)-80} more rows')

for p in ['input/gameRule/VegasBlitz_GameRule.xlsx','input/mathModel/Parsheet_Vegas_Blitz.xlsx']:
    load(p)
