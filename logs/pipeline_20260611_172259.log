int countNonzero(const vector<vector<Symbol>> &pay_window, Symbol target_symbol){
    // count nonzero
    int count = 0;
    for (int i = 0; i < pay_window.size(); i++){
        for(int j = 0; j < pay_window[0].size(); j++){
            if(pay_window[i][j] == target_symbol) count ++;
        }
    }
    return count;
}

