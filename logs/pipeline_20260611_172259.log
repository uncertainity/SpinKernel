SYMBOLS
HV1, HV2, HV3, HV4, HV5, LV1, LV2, LV3, LV4, LV5, LV6, WILD, SCAT, COR, COLLECT
alias SCATTER -> SCAT

REELSETS
BG1_Reels -> planner.reel_strips.base_B1, ReelSize shape [6]
BG2_Reels -> planner.reel_strips.base_B2, ReelSize shape [6]
FG1_Reels -> planner.reel_strips.free_F1, ReelSize shape [6]

